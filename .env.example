# BirdTab Chrome Extension - Environment Variables
# Copy this file to .env.local (for development) and .env.production (for production builds)

# ===========================================
# BACKEND URLS
# ===========================================

# Website URL (used for pricing links, upgrade CTAs)
WEBSITE_URL=http://localhost:3000

# API Server URL (used for bird data, license verification)
API_SERVER_URL=http://localhost:3000/api

# ===========================================
# SENTRY CONFIGURATION (for source map uploads)
# ===========================================

# Sentry Auth Token - Required for source map uploads during build
# Get this from: https://sentry.io/settings/auth-tokens/
# Required scopes: org:ci (or project:releases + org:read for user tokens)
SENTRY_AUTH_TOKEN=

# Sentry Organization slug
# Find this in your Sentry dashboard URL: https://sentry.io/organizations/{org-slug}/
SENTRY_ORG=birdtab

# Sentry Project slug
# Find this in your Sentry project settings
SENTRY_PROJECT=birdtab-extension

# ===========================================
# POSTHOG ANALYTICS
# ===========================================

# PostHog API Key (use dev key in .env.local, prod key in .env.production)
POSTHOG_API_KEY=

# ===========================================
# SECURITY
# ===========================================

# Uninstall URL signing secret (HMAC-SHA256)
# Must match the secret configured on api.birdtab.app
UNINSTALL_SECRET=birdtab-uninstall-secret-change-in-prod
